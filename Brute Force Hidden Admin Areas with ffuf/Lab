Task 1: Set Up Test Environment and Basic ffuf Usage
Step 1: Configure Test Web Application
Create a local web application with hidden admin areas for testing:

# Start nginx web server
sudo systemctl start nginx

# Create test directory structure
sudo mkdir -p /var/www/html/{admin,administrator,management,wp-admin}

# Create sample admin page
sudo tee /var/www/html/admin/index.html > /dev/null << 'EOF'
<!DOCTYPE html>
<html>
<head><title>Admin Login</title></head>
<body>
<h1>Administrator Login</h1>
<form>
<input type="text" placeholder="Username">
<input type="password" placeholder="Password">
<button type="submit">Login</button>
</form>
</body>
</html>
EOF

# Set permissions
sudo chown -R www-data:www-data /var/www/html/
sudo chmod -R 755 /var/www/html/

# Verify server is running
curl -I http://localhost
Step 2: Install ffuf and Prepare Wordlists
# Install ffuf
wget https://github.com/ffuf/ffuf/releases/download/v2.1.0/ffuf_2.1.0_linux_amd64.tar.gz
tar -xzf ffuf_2.1.0_linux_amd64.tar.gz
sudo mv ffuf /usr/local/bin/
ffuf -V

# Create wordlist directory
mkdir -p ~/wordlists

# Create custom admin wordlist
cat > ~/wordlists/admin-paths.txt << 'EOF'
admin
administrator
wp-admin
admin.php
login
management
manager
control-panel
dashboard
panel
backend
adminpanel
admin-panel
administration
controlpanel
EOF
Step 3: Perform Basic Directory Fuzzing
# Basic directory enumeration
ffuf -w ~/wordlists/admin-paths.txt -u http://localhost/FUZZ -mc 200,301,302,403

# Parameters:
# -w: wordlist file
# -u: target URL (FUZZ is replaced with wordlist entries)
# -mc: match HTTP status codes to display

# Enhanced fuzzing with filtering
ffuf -w ~/wordlists/admin-paths.txt \
     -u http://localhost/FUZZ \
     -mc 200,301,302,403,401 \
     -fc 404 \
     -t 50 \
     -v

# Additional parameters:
# -fc: filter out status codes
# -t: number of concurrent threads
# -v: verbose output
Step 4: Advanced ffuf Techniques
# Filter by response size to eliminate false positives
ffuf -w ~/wordlists/admin-paths.txt \
     -u http://localhost/FUZZ \
     -mc 200,301,302,403 \
     -fs 162

# Fuzz with multiple wordlists (paths and extensions)
cat > ~/wordlists/extensions.txt << 'EOF'
.php
.html
.asp
.jsp
EOF

ffuf -w ~/wordlists/admin-paths.txt:PATHS \
     -w ~/wordlists/extensions.txt:EXT \
     -u http://localhost/FUZZPATHSFUZZEXT \
     -mc 200,301,302,403

# Save results to file
ffuf -w ~/wordlists/admin-paths.txt \
     -u http://localhost/FUZZ \
     -mc 200,301,302,403 \
     -o results.json \
     -of json
