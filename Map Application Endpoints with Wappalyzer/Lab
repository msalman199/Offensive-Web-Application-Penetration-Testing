#!/usr/bin/env python3

import subprocess
import json
import requests
import time
import sys
from datetime import datetime
from urllib.parse import urljoin, urlparse
import os

class EndpointMapper:
    def __init__(self, target_url):
        self.target_url = target_url
        self.results = {
            'target': target_url,
            'timestamp': datetime.now().isoformat(),
            'technologies': {},
            'endpoints': [],
            'status_codes': {},
            'interesting_files': []
        }
    
    def run_wappalyzer(self):
        """Run Wappalyzer to detect technologies"""
        print(f"[+] Running Wappalyzer on {self.target_url}")
        try:
            cmd = ['wappalyzer', self.target_url, '--pretty']
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            
            if result.returncode == 0:
                tech_data = json.loads(result.stdout)
                self.results['technologies'] = tech_data
                print(f"[+] Detected {len(tech_data.get('technologies', []))} technologies")
            else:
                print(f"[-] Wappalyzer error: {result.stderr}")
        except Exception as e:
            print(f"[-] Wappalyzer exception: {str(e)}")
    
    def run_dirsearch(self):
        """Run dirsearch to find endpoints"""
        print(f"[+] Running dirsearch on {self.target_url}")
        try:
            # Create temporary output file
            temp_output = f"/tmp/dirsearch_{int(time.time())}.json"
            
            cmd = [
                'python3', 
                os.path.expanduser('~/dirsearch/dirsearch.py'),
                '-u', self.target_url,
                '-e', 'php,html,js,txt,json,xml',
                '--format=json',
                '-o', temp_output,
                '--quiet'
            ]
            
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
            
            # Read results from file
            if os.path.exists(temp_output):
                with open(temp_output, 'r') as f:
                    dirsearch_data = json.load(f)
                    
                # Process dirsearch results
                for entry in dirsearch_data.get('results', []):
                    endpoint_info = {
                        'url': entry.get('url', ''),
                        'status': entry.get('status', 0),
                        'length': entry.get('length', 0),
                        'content_type': entry.get('content-type', ''),
                        'redirect': entry.get('redirect', '')
                    }
                    self.results['endpoints'].append(endpoint_info)
                    
                    # Track status codes
                    status = str(entry.get('status', 0))
                    if status in self.results['status_codes']:
                        self.results['status_codes'][status] += 1
                    else:
                        self.results['status_codes'][status] = 1
                
                # Clean up
                os.remove(temp_output)
                print(f"[+] Found {len(self.results['endpoints'])} endpoints")
            else:
                print("[-] Dirsearch output file not found")
                
        except Exception as e:
            print(f"[-] Dirsearch exception: {str(e)}")
    
    def analyze_endpoints(self):
        """Analyze discovered endpoints for interesting patterns"""
        print("[+] Analyzing endpoints for interesting patterns")
        
        interesting_patterns = [
            'admin', 'login', 'api', 'config', 'backup',
            'test', 'debug', 'swagger', 'docs', 'upload'
        ]
        
        for endpoint in self.results['endpoints']:
            url = endpoint['url'].lower()
            for pattern in interesting_patterns:
                if pattern in url and endpoint['status'] in [200, 301, 302]:
                    self.results['interesting_files'].append({
                        'url': endpoint['url'],
                        'pattern': pattern,
                        'status': endpoint['status'],
                        'reason': f"Contains '{pattern}' pattern"
                    })
    
    def test_common_endpoints(self):
        """Test for common API endpoints"""
        print("[+] Testing common API endpoints")
        
        common_endpoints = [
            '/api', '/api/v1', '/api/v2',
            '/swagger', '/swagger.json', '/swagger-ui',
            '/docs', '/documentation',
            '/health', '/status', '/ping',
            '/admin', '/admin/login',
            '/login', '/logout',
            '/users', '/user',
            '/config', '/configuration'
        ]
        
        for endpoint in common_endpoints:
            try:
                full_url = urljoin(self.target_url, endpoint)
                response = requests.get(full_url, timeout=10, allow_redirects=False)
                
                if response.status_code in [200, 301, 302, 401, 403]:
                    endpoint_info = {
                        'url': full_url,
                        'status': response.status_code,
                        'length': len(response.content),
                        'content_type': response.headers.get('content-type', ''),
                        'redirect': response.headers.get('location', '')
                    }
                    
                    # Avoid duplicates
                    if not any(ep['url'] == full_url for ep in self.results['endpoints']):
                        self.results['endpoints'].append(endpoint_info)
                        
                        # Update status codes
                        status = str(response.status_code)
                        if status in self.results['status_codes']:
                            self.results['status_codes'][status] += 1
                        else:
                            self.results['status_codes'][status] = 1
                
                time.sleep(0.5)  # Be respectful
                
            except requests.RequestException:
                continue
    
    def generate_report(self):
        """Generate a comprehensive report"""
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        report_file = f"endpoint_mapping_report_{timestamp}.json"
        
        with open(report_file, 'w') as f:
            json.dump(self.results, f, indent=2)
        
        # Generate human-readable summary
        summary_file = f"endpoint_mapping_summary_{timestamp}.txt"
        with open(summary_file, 'w') as f:
            f.write(f"Endpoint Mapping Report for {self.target_url}\n")
            f.write("=" * 50 + "\n\n")
            
            f.write(f"Scan Date: {self.results['timestamp']}\n")
            f.write(f"Target: {self.results['target']}\n\n")
            
            # Technologies
            f.write("Detected Technologies:\n")
            f.write("-" * 20 + "\n")
            if self.results['technologies']:
                for tech in self.results['technologies'].get('technologies', []):
                    f.write(f"- {tech.get('name', 'Unknown')}")
                    if tech.get('version'):
                        f.write(f" (v{tech['version']})")
                    f.write("\n")
            else:
                f.write("No technologies detected\n")
            f.write("\n")
            
            # Status code summary
            f.write("Status Code Summary:\n")
            f.write("-" * 20 + "\n")
            for status, count in sorted(self.results['status_codes'].items()):
                f.write(f"{status}: {count} endpoints\n")
            f.write("\n")
            
            # Interesting endpoints
            f.write("Interesting Endpoints:\n")
            f.write("-" * 20 + "\n")
            for item in self.results['interesting_files']:
                f.write(f"- {item['url']} (Status: {item['status']}) - {item['reason']}\n")
            f.write("\n")
            
            # All endpoints
            f.write("All Discovered Endpoints:\n")
            f.write("-" * 25 + "\n")
            for endpoint in sorted(self.results['endpoints'], key=lambda x: x['status']):
                f.write(f"{endpoint['status']} - {endpoint['url']}\n")
        
        print(f"[+] Report saved to {report_file}")
        print(f"[+] Summary saved to {summary_file}")
        
        return report_file, summary_file

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 endpoint_mapper.py <target_url>")
        print("Example: python3 endpoint_mapper.py https://httpbin.org")
        sys.exit(1)
    
    target_url = sys.argv[1]
    
    # Validate URL
    parsed = urlparse(target_url)
    if not parsed.scheme or not parsed.netloc:
        print("[-] Invalid URL provided")
        sys.exit(1)
    
    print(f"[+] Starting endpoint mapping for {target_url}")
    print("=" * 50)
    
    mapper = EndpointMapper(target_url)
    
    # Run all analysis steps
    mapper.run_wappalyzer()
    mapper.run_dirsearch()
    mapper.test_common_endpoints()
    mapper.analyze_endpoints()
    
    # Generate reports
    report_file, summary_file = mapper.generate_report()
    
    print("\n" + "=" * 50)
    print("[+] Endpoint mapping completed!")
    print(f"[+] Found {len(mapper.results['endpoints'])} total endpoints")
    print(f"[+] Found {len(mapper.results['interesting_files'])} interesting endpoints")
    print(f"[+] Detailed report: {report_file}")
    print(f"[+] Summary report: {summary_file}")

if __name__ == "__main__":
    main()
