#!/usr/bin/env python3

import json
import glob
import sys
from collections import defaultdict

def compare_reports():
    """Compare multiple endpoint mapping reports"""
    report_files = glob.glob("endpoint_mapping_report_*.json")
    
    if not report_files:
        print("[-] No report files found")
        return
    
    print(f"[+] Found {len(report_files)} report files")
    
    # Aggregate data
    all_technologies = defaultdict(int)
    all_status_codes = defaultdict(int)
    common_endpoints = defaultdict(int)
    
    for report_file in report_files:
        try:
            with open(report_file, 'r') as f:
                data = json.load(f)
            
            # Count technologies
            for tech in data.get('technologies', {}).get('technologies', []):
                tech_name = tech.get('name', 'Unknown')
                all_technologies[tech_name] += 1
            
            # Count status codes
            for status, count in data.get('status_codes', {}).items():
                all_status_codes[status] += count
            
            # Count common endpoint patterns
            for endpoint in data.get('endpoints', []):
                url_path = endpoint.get('url', '').split('/')[-1].lower()
                if url_path:
                    common_endpoints[url_path] += 1
                    
        except Exception as e:
            print(f"[-] Error processing {report_file}: {str(e)}")
    
    # Generate comparison report
    print("\n" + "=" * 50)
    print("ENDPOINT MAPPING COMPARISON REPORT")
    print("=" * 50)
    
    print(f"\nTargets Analyzed: {len(report_files)}")
    
    print(f"\nMost Common Technologies:")
    print("-" * 25)
    for tech, count in sorted(all_technologies.items(), key=lambda x: x[1], reverse=True)[:10]:
        print(f"{tech}: {count} targets")
    
    print(f"\nStatus Code Distribution:")
    print("-" * 25)
    for status, count in sorted(all_status_codes.items()):
        print(f"{status}: {count} endpoints")
    
    print(f"\nMost Common Endpoint Names:")
    print("-" * 30)
    for endpoint, count in sorted(common_endpoints.items(), key=lambda x: x[1], reverse=True)[:15]:
        if len(endpoint) > 2:  # Filter out very short names
            print(f"{endpoint}: found on {count} targets")

if __name__ == "__main__":
    compare_reports()
