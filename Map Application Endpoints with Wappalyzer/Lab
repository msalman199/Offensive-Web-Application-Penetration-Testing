    print(f"[+] Processing {len(targets)} targets")
    
    for i, target in enumerate(targets, 1):
        print(f"\n[+] Processing target {i}/{len(targets)}: {target}")
        print("-" * 60)
        
        try:
            # Run the endpoint mapper for each target
            cmd = ['python3', 'endpoint_mapper.py', target]
            result = subprocess.run(cmd, timeout=600)  # 10 minute timeout per target
            
            if result.returncode == 0:
                print(f"[+] Successfully processed {target}")
            else:
                print(f"[-] Error processing {target}")
                
        except subprocess.TimeoutExpired:
            print(f"[-] Timeout processing {target}")
        except Exception as e:
            print(f"[-] Exception processing {target}: {str(e)}")
    
    print(f"\n[+] Batch processing completed!")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 batch_endpoint_mapper.py <target_file>")
        sys.exit(1)
    
