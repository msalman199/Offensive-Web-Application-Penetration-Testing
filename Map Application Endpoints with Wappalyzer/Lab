#!/usr/bin/env python3

import subprocess
import json
import sys
from datetime import datetime

def run_wappalyzer(url):
    """Run Wappalyzer analysis on a given URL"""
    try:
        cmd = ['wappalyzer', url, '--pretty']
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        
        if result.returncode == 0:
            return json.loads(result.stdout)
        else:
            print(f"Error analyzing {url}: {result.stderr}")
            return None
    except subprocess.TimeoutExpired:
        print(f"Timeout analyzing {url}")
        return None
    except json.JSONDecodeError:
        print(f"Invalid JSON response for {url}")
        return None

def analyze_targets(target_file):
    """Analyze multiple targets from a file"""
    results = {}
    
    try:
        with open(target_file, 'r') as f:
            targets = [line.strip() for line in f if line.strip()]
    except FileNotFoundError:
        print(f"Target file {target_file} not found")
        return
    
    for target in targets:
        print(f"Analyzing {target}...")
        result = run_wappalyzer(target)
        if result:
            results[target] = result
    
    # Save results
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    output_file = f"wappalyzer_batch_{timestamp}.json"
    
    with open(output_file, 'w') as f:
        json.dump(results, f, indent=2)
    
    print(f"Results saved to {output_file}")
    return results

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python3 batch_wappalyzer.py <target_file>")
        sys.exit(1)
    
    analyze_targets(sys.argv[1])
