#!/usr/bin/env python3
import requests
import base64
import urllib.parse
import html
import time
import json
from datetime import datetime

class AutomatedPayloadTester:
    def __init__(self, target_url):
        self.target_url = target_url
        self.session = requests.Session()
        self.results = []
    
    def generate_payloads(self, original_payload):
        """Generate various obfuscated payloads"""
        payloads = {
            'original': original_payload,
            'base64': base64.b64encode(original_payload.encode()).decode(),
            'url_encoded': urllib.parse.quote(original_payload),
            'double_url_encoded': urllib.parse.quote(urllib.parse.quote(original_payload)),
            'html_encoded': html.escape(original_payload),
            'mixed_case': self.mixed_case_transform(original_payload),
            'with_null_bytes': original_payload.replace('<', '<\x00'),
            'unicode_encoded': self.unicode_encode(original_payload)
        }
        return payloads
    
    def mixed_case_transform(self, payload):
        """Transform payload to mixed case"""
        result = ""
        for i, char in enumerate(payload):
            if char.isalpha():
                result += char.upper() if i % 2 == 0 else char.lower()
            else:
                result += char
        return result
    
    def unicode_encode(self, payload):
        """Encode special characters as Unicode"""
        result = ""
        for char in payload:
            if char in '<>"\'&':
                result += f"\\u{ord(char):04x}"
            else:
                result += char
        return result
    
    def test_payload(self, payload_name, payload_value):
        """Test a single payload against the target"""
        try:
            data = {'comment': payload_value, 'username': 'testuser'}
            
            start_time = time.time()
            response = self.session.post(self.target_url, data=data, timeout=10)
            end_time = time.time()
            
            result = {
                'payload_name': payload_name,
                'payload_value': payload_value,
                'status_code': response.status_code,
                'response_time': round(end_time - start_time, 3),
                'response_length': len(response.text),
                'timestamp': datetime.now().isoformat(),
                'reflected': payload_value in response.text,
                'error_detected': any(error in response.text.lower() 
                                    for error in ['error', 'exception', 'warning'])
            }
            
            self.results.append(result)
            return result
            
        except requests.exceptions.RequestException as e:
            error_result = {
                'payload_name': payload_name,
                'payload_value': payload_value,
                'error': str(e),
                'timestamp': datetime.now().isoformat()
            }
            self.results.append(error_result)
            return error_result
    
    def run_test_suite(self, original_payload):
        """Run complete test suite with all payload variations"""
        print(f"Starting automated payload testing...")
        print(f"Target URL: {self.target_url}")
        print(f"Original Payload: {original_payload}")
        print("=" * 60)
        
        payloads = self.generate_payloads(original_payload)
        
        for payload_name, payload_value in payloads.items():
            print(f"Testing {payload_name}...")
            result = self.test_payload(payload_name, payload_value)
            
            if 'error' not in result:
                status = "SUCCESS" if result['status_code'] == 200 else "FAILED"
                reflected = "REFLECTED" if result['reflected'] else "NOT REFLECTED"
                print(f"  Status: {status} | Response Time: {result['response_time']}s | {reflected}")
            else:
                print(f"  ERROR: {result['error']}")
            
            time.sleep(1)  # Be respectful to the target
        
        print("\nTest completed!")
        return self.results
    
    def generate_report(self, filename="payload_test_report.json"):
        """Generate detailed test report"""
        report = {
            'test_summary': {
                'target_url': self.target_url,
                'total_tests': len(self.results),
                'successful_tests': len([r for r in self.results if 'error' not in r]),
                'failed_tests': len([r for r in self.results if 'error' in r]),
                'reflected_payloads': len([r for r in self.results if r.get('reflected', False)]),
                'timestamp': datetime.now().isoformat()
            },
            'detailed_results': self.results
        }
        
        with open(filename, 'w') as f:
            json.dump(report, f, indent=2)
        
        print(f"Detailed report saved to {filename}")
        return report

def main():
    # Use httpbin.org for safe testing
    target_url = "http://httpbin.org/post"
    
    # Test payloads
    test_payloads = [
        "<script>alert('XSS')</script>",
        "' OR 1=1--",
        "document.cookie",
        "<img src=x onerror=alert(1)>"
    ]
    
    for payload in test_payloads:
        print(f"\n{'='*80}")
        print(f"Testing payload: {payload}")
        print(f"{'='*80}")
        
        tester = AutomatedPayloadTester(target_url)
        results = tester.run_test_suite(payload)
        
        # Generate report
        report_filename = f"report_{hash(payload) % 10000}.json"
        tester.generate_report(report_filename)
        
        print(f"\nSummary for '{payload}':")
        successful = len([r for r in results if 'error' not in r])
        reflected = len([r for r in results if r.get('reflected', False)])
        print(f"  Successful tests: {successful}/{len(results)}")
        print(f"  Reflected payloads: {reflected}")

if __name__ == "__main__":
    main()
