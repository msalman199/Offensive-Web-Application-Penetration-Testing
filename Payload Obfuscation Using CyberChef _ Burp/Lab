#!/usr/bin/env python3
import base64
import urllib.parse
import html
import binascii

class PayloadObfuscator:
    def __init__(self):
        self.original_payload = ""
        self.obfuscated_payloads = {}
    
    def set_payload(self, payload):
        """Set the original payload to obfuscate"""
        self.original_payload = payload
        self.obfuscated_payloads = {}
    
    def base64_encode(self):
        """Encode payload using Base64"""
        encoded = base64.b64encode(self.original_payload.encode()).decode()
        self.obfuscated_payloads['base64'] = encoded
        return encoded
    
    def url_encode(self):
        """URL encode the payload"""
        encoded = urllib.parse.quote(self.original_payload)
        self.obfuscated_payloads['url'] = encoded
        return encoded
    
    def double_url_encode(self):
        """Double URL encode the payload"""
        first_encode = urllib.parse.quote(self.original_payload)
        double_encoded = urllib.parse.quote(first_encode)
        self.obfuscated_payloads['double_url'] = double_encoded
        return double_encoded
    
    def html_encode(self):
        """HTML entity encode the payload"""
        encoded = html.escape(self.original_payload)
        self.obfuscated_payloads['html'] = encoded
        return encoded
    
    def hex_encode(self):
        """Convert payload to hexadecimal"""
        encoded = binascii.hexlify(self.original_payload.encode()).decode()
        self.obfuscated_payloads['hex'] = encoded
        return encoded
    
    def char_code_encode(self):
        """Convert to JavaScript character codes"""
        char_codes = [str(ord(char)) for char in self.original_payload]
        encoded = "String.fromCharCode(" + ",".join(char_codes) + ")"
        self.obfuscated_payloads['charcode'] = encoded
        return encoded
    
    def get_all_encodings(self):
        """Generate all encoding variations"""
        encodings = {}
        encodings['original'] = self.original_payload
        encodings['base64'] = self.base64_encode()
        encodings['url'] = self.url_encode()
        encodings['double_url'] = self.double_url_encode()
        encodings['html'] = self.html_encode()
        encodings['hex'] = self.hex_encode()
        encodings['charcode'] = self.char_code_encode()
        return encodings

def main():
    obfuscator = PayloadObfuscator()
    
    # Test payloads
    test_payloads = [
        "<script>alert('XSS')</script>",
        "' OR 1=1 UNION SELECT * FROM users--",
        "document.cookie",
        "../../../etc/passwd"
    ]
    
    for payload in test_payloads:
        print(f"\n{'='*50}")
        print(f"Original Payload: {payload}")
        print(f"{'='*50}")
        
        obfuscator.set_payload(payload)
        encodings = obfuscator.get_all_encodings()
        
        for encoding_type, encoded_payload in encodings.items():
            print(f"{encoding_type.upper()}: {encoded_payload}")

if __name__ == "__main__":
    main()
