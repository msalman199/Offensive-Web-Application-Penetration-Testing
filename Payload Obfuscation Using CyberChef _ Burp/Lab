#!/usr/bin/env python3
import base64
import urllib.parse
import html
import sys

def generate_burp_payloads(original_payload):
    """Generate various obfuscated payloads for Burp testing"""
    
    payloads = []
    
    # Original payload
    payloads.append(("Original", original_payload))
    
    # Base64 encoding
    base64_payload = base64.b64encode(original_payload.encode()).decode()
    payloads.append(("Base64", base64_payload))
    
    # URL encoding
    url_payload = urllib.parse.quote(original_payload)
    payloads.append(("URL Encoded", url_payload))
    
    # Double URL encoding
    double_url_payload = urllib.parse.quote(urllib.parse.quote(original_payload))
    payloads.append(("Double URL Encoded", double_url_payload))
    
    # HTML entity encoding
    html_payload = html.escape(original_payload)
    payloads.append(("HTML Encoded", html_payload))
    
    # Mixed case (for case-insensitive filters)
    mixed_case_payload = ""
    for i, char in enumerate(original_payload):
        if char.isalpha():
            mixed_case_payload += char.upper() if i % 2 == 0 else char.lower()
        else:
            mixed_case_payload += char
    payloads.append(("Mixed Case", mixed_case_payload))
    
    # Character code representation
    char_codes = [str(ord(char)) for char in original_payload]
    charcode_payload = "String.fromCharCode(" + ",".join(char_codes) + ")"
    payloads.append(("Character Codes", charcode_payload))
    
    return payloads

def create_burp_request_template(payloads, target_url="http://httpbin.org/post"):
    """Create HTTP request templates for Burp Repeater"""
    
    print("HTTP Request Templates for Burp Repeater:")
    print("=" * 50)
    
    for name, payload in payloads:
        print(f"\n--- {name} ---")
        request_template = f"""POST /post HTTP/1.1
Host: httpbin.org
Content-Type: application/x-www-form-urlencoded
Content-Length: {len(f'comment={payload}')}

comment={payload}"""
        print(request_template)
        print("-" * 30)

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 burp_payload_generator.py '<payload>'")
        print("Example: python3 burp_payload_generator.py '<script>alert(1)</script>'")
        sys.exit(1)
    
    original_payload = sys.argv[1]
    payloads = generate_burp_payloads(original_payload)
    
    print(f"Generated {len(payloads)} payload variations:")
    print("=" * 50)
    
    for name, payload in payloads:
        print(f"{name}: {payload}")
    
    print("\n")
    create_burp_request_template(payloads)
    
    # Save to file
    with open("burp_payloads.txt", "w") as f:
        f.write(f"Payload variations for: {original_payload}\n")
        f.write("=" * 50 + "\n\n")
        for name, payload in payloads:
            f.write(f"{name}: {payload}\n")
    
    print(f"\nPayloads saved to burp_payloads.txt")

if __name__ == "__main__":
    main()
