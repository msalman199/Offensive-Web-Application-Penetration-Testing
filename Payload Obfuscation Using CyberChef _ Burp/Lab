#!/usr/bin/env python3
import base64
import urllib.parse
import html
import binascii
import json
import random
import string

class AdvancedPayloadObfuscator:
    def __init__(self):
        self.payload = ""
    
    def set_payload(self, payload):
        self.payload = payload
    
    def chain_encodings(self, encodings_list):
        """Chain multiple encoding methods"""
        result = self.payload
        for encoding in encodings_list:
            if encoding == 'base64':
                result = base64.b64encode(result.encode()).decode()
            elif encoding == 'url':
                result = urllib.parse.quote(result)
            elif encoding == 'html':
                result = html.escape(result)
            elif encoding == 'hex':
                result = binascii.hexlify(result.encode()).decode()
        return result
    
    def random_case_obfuscation(self):
        """Randomly change case of characters"""
        result = ""
        for char in self.payload:
            if char.isalpha():
                result += char.upper() if random.choice([True, False]) else char.lower()
            else:
                result += char
        return result
    
    def insert_random_comments(self):
        """Insert random HTML/JS comments"""
        if '<script>' in self.payload.lower():
            # Insert comments in JavaScript
            result = self.payload.replace('<script>', '<script>/*comment*/')
            result = result.replace('</script>', '/*comment*/</script>')
            return result
        return self.payload
    
    def unicode_encode(self):
        """Encode using Unicode escape sequences"""
        result = ""
        for char in self.payload:
            if ord(char) > 127 or char in '<>"\'&':
                result += f"\\u{ord(char):04x}"
            else:
                result += char
        return result
    
    def generate_obfuscation_report(self):
        """Generate comprehensive obfuscation report"""
        report = {
            'original': self.payload,
            'single_encodings': {},
            'chained_encodings': {},
            'advanced_techniques': {}
        }
        
        # Single encodings
        report['single_encodings']['base64'] = base64.b64encode(self.payload.encode()).decode()
        report['single_encodings']['url'] = urllib.parse.quote(self.payload)
        report['single_encodings']['html'] = html.escape(self.payload)
        report['single_encodings']['hex'] = binascii.hexlify(self.payload.encode()).decode()
        
        # Chained encodings
        report['chained_encodings']['base64_url'] = self.chain_encodings(['base64', 'url'])
        report['chained_encodings']['html_url'] = self.chain_encodings(['html', 'url'])
        report['chained_encodings']['hex_base64'] = self.chain_encodings(['hex', 'base64'])
        
        # Advanced techniques
        report['advanced_techniques']['random_case'] = self.random_case_obfuscation()
        report['advanced_techniques']['with_comments'] = self.insert_random_comments()
        report['advanced_techniques']['unicode'] = self.unicode_encode()
        
        return report

def save_report_to_file(report, filename):
    """Save obfuscation report to JSON file"""
    with open(filename, 'w') as f:
        json.dump(report, f, indent=2)
    print(f"Report saved to {filename}")

def main():
    obfuscator = AdvancedPayloadObfuscator()
    
    # Interactive mode
    print("Advanced Payload Obfuscator")
    print("=" * 30)
    
    while True:
        payload = input("\nEnter payload to obfuscate (or 'quit' to exit): ")
        if payload.lower() == 'quit':
            break
        
        obfuscator.set_payload(payload)
        report = obfuscator.generate_obfuscation_report()
        
        print(f"\nObfuscation Report for: {payload}")
        print("-" * 50)
        
        for category, methods in report.items():
            if category == 'original':
                continue
            print(f"\n{category.upper().replace('_', ' ')}:")
            if isinstance(methods, dict):
                for method, result in methods.items():
                    print(f"  {method}: {result}")
            else:
                print(f"  {methods}")
        
        # Save report option
        save_option = input("\nSave report to file? (y/n): ")
        if save_option.lower() == 'y':
            filename = f"obfuscation_report_{hash(payload) % 10000}.json"
            save_report_to_file(report, filename)

if __name__ == "__main__":
    main()
