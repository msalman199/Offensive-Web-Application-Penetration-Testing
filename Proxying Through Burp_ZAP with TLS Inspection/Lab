#!/usr/bin/env python3
"""
Simple traffic analysis script
Analyzes Burp Suite proxy logs for common security issues
"""

import re
import json
from pathlib import Path

def analyze_requests(log_file):
    """Analyze HTTP requests for security issues"""
    issues = []
    
    with open(log_file, 'r') as f:
        content = f.read()
    
    # Check for sensitive data in URLs
    if re.search(r'password=|token=|api_key=', content, re.IGNORECASE):
        issues.append("Sensitive data found in URL parameters")
    
    # Check for unencrypted authentication
    if re.search(r'Authorization: Basic', content):
        issues.append("Basic authentication detected")
    
    # Check for session tokens
    if re.search(r'session|JSESSIONID|PHPSESSID', content, re.IGNORECASE):
        issues.append("Session tokens identified")
    
    return issues

