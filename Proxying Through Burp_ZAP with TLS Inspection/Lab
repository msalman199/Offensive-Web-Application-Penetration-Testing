Subtask 3.1: Create Certificate Management Script
Create a Python script to automate certificate installation and proxy configuration:

#!/usr/bin/env python3
"""
Burp Suite TLS Inspection Automation Script
Automates proxy configuration and certificate management
"""

import os
import sys
import subprocess
import requests
import time
from pathlib import Path

class BurpProxyManager:
    def __init__(self, proxy_host="127.0.0.1", proxy_port=8080):
        self.proxy_host = proxy_host
        self.proxy_port = proxy_port
        self.proxy_url = f"http://{proxy_host}:{proxy_port}"
        self.cert_path = Path.home() / "burp-certificates"
        self.cert_path.mkdir(exist_ok=True)
        
    def check_burp_running(self):
        """Check if Burp Suite is running and accessible"""
        try:
            response = requests.get(
                f"http://{self.proxy_host}:{self.proxy_port}",
                timeout=5
            )
            return True
        except requests.exceptions.RequestException:
            return False
    
    def download_ca_certificate(self):
        """Download Burp's CA certificate"""
        cert_url = f"http://{self.proxy_host}:{self.proxy_port}/cert"
        cert_file = self.cert_path / "cacert.der"
        
        try:
            print(f"Downloading CA certificate from {cert_url}")
            response = requests.get(cert_url, timeout=10)
            response.raise_for_status()
            
            with open(cert_file, 'wb') as f:
                f.write(response.content)
            
            print(f"Certificate saved to {cert_file}")
            return cert_file
            
        except requests.exceptions.RequestException as e:
            print(f"Error downloading certificate: {e}")
            return None
    
    def convert_certificate(self, der_file):
        """Convert DER certificate to PEM format"""
        pem_file = self.cert_path / "burp-ca-cert.pem"
        
        try:
            cmd = [
                "openssl", "x509", "-inform", "DER",
                "-in", str(der_file),
                "-out", str(pem_file)
            ]
            
            result = subprocess.run(cmd, capture_output=True, text=True)
            
            if result.returncode == 0:
                print(f"Certificate converted to PEM format: {pem_file}")
                return pem_file
            else:
                print(f"Error converting certificate: {result.stderr}")
                return None
                
        except subprocess.SubprocessError as e:
            print(f"Error running openssl: {e}")
            return None
    
    def install_system_certificate(self, pem_file):
        """Install certificate system-wide"""
        try:
            # Copy to system certificate directory
            dest_file = "/usr/local/share/ca-certificates/burp-ca-cert.crt"
            
            cmd = ["sudo", "cp", str(pem_file), dest_file]
            result = subprocess.run(cmd, capture_output=True, text=True)
            
            if result.returncode != 0:
                print(f"Error copying certificate: {result.stderr}")
                return False
            
            # Update certificate store
            cmd = ["sudo", "update-ca-certificates"]
            result = subprocess.run(cmd, capture_output=True, text=True)
            
            if result.returncode == 0:
                print("System certificate store updated successfully")
                return True
            else:
                print(f"Error updating certificate store: {result.stderr}")
                return False
                
        except subprocess.SubprocessError as e:
            print(f"Error installing certificate: {e}")
            return False
    
    def configure_environment_proxy(self):
        """Set environment variables for proxy"""
        proxy_settings = {
            'http_proxy': self.proxy_url,
            'https_proxy': self.proxy_url,
            'HTTP_PROXY': self.proxy_url,
            'HTTPS_PROXY': self.proxy_url
        }
        
        for key, value in proxy_settings.items():
            os.environ[key] = value
        
        print("Environment proxy variables set")
        return proxy_settings
    
    def test_https_interception(self):
        """Test HTTPS traffic interception"""
        test_urls = [
            "https://httpbin.org/get",
            "https://jsonplaceholder.typicode.com/posts/1"
        ]
        
        proxies = {
            'http': self.proxy_url,
            'https': self.proxy_url
        }
        
        print("Testing HTTPS interception...")
        
        for url in test_urls:
            try:
                response = requests.get(
                    url, 
                    proxies=proxies, 
                    timeout=10,
                    verify=True  # Verify SSL certificates
                )
                
                if response.status_code == 200:
                    print(f"✓ Successfully intercepted: {url}")
                else:
                    print(f"✗ Failed to intercept: {url} (Status: {response.status_code})")
                    
            except requests.exceptions.RequestException as e:
                print(f"✗ Error testing {url}: {e}")
    
    def setup_complete_interception(self):
        """Complete setup process"""
        print("=== Burp Suite TLS Interception Setup ===")
        
        # Check if Burp is running
        if not self.check_burp_running():
            print("Error: Burp Suite is not running or not accessible")
            print(f"Please ensure Burp is running on {self.proxy_host}:{self.proxy_port}")
            return False
        
        print("✓ Burp Suite is running and accessible")
        
        # Download certificate
        cert_file = self.download_ca_certificate()
        if not cert_file:
            return False
        
        # Convert certificate
        pem_file = self.convert_certificate(cert_file)
        if not pem_file:
            return False
        
        # Install certificate
        if not self.install_system_certificate(pem_file):
            return False
        
        # Configure proxy
        self.configure_environment_proxy()
        
        # Test interception
        time.sleep(2)  # Wait for certificate installation
        self.test_https_interception()
        
        print("\n=== Setup Complete ===")
        print("TLS interception is now configured and ready to use")
        return True

def main():
    """Main function"""
    if len(sys.argv) > 1:
        if sys.argv[1] == "--test":
            manager = BurpProxyManager()
            manager.test_https_interception()
            return
    
    manager = BurpProxyManager()
    success = manager.setup_complete_interception()
    
    if success:
        print("\nNext steps:")
        print("1. Configure your browser to use proxy 127.0.0.1:8080")
        print("2. Browse to HTTPS websites")
        print("3. Check Burp Suite's HTTP history for intercepted traffic")
    else:
        print("\nSetup failed. Please check the errors above and try again.")

if __name__ == "__main__":
    main()
