#!/usr/bin/env python3
"""
Traffic Generation Script for Burp Suite Testing
Generates various types of HTTP/HTTPS requests for interception analysis
"""

import requests
import json
import time
import random
from urllib.parse import urljoin

class TrafficGenerator:
    def __init__(self, proxy_host="127.0.0.1", proxy_port=8080):
        self.proxies = {
            'http': f'http://{proxy_host}:{proxy_port}',
            'https': f'http://{proxy_host}:{proxy_port}'
        }
        self.session = requests.Session()
        self.session.proxies.update(self.proxies)
    
    def generate_get_requests(self):
        """Generate various GET requests"""
        urls = [
            "https://httpbin.org/get",
            "https://httpbin.org/headers",
            "https://httpbin.org/user-agent",
            "https://jsonplaceholder.typicode.com/posts",
            "https://jsonplaceholder.typicode.com/users"
        ]
        
        print("Generating GET requests...")
        for url in urls:
            try:
                response = self.session.get(url, timeout=10)
                print(f"GET {url} - Status: {response.status_code}")
                time.sleep(1)
            except requests.exceptions.RequestException as e:
                print(f"Error with GET {url}: {e}")
    
    def generate_post_requests(self):
        """Generate POST requests with data"""
        post_data = [
            {
                "url": "https://httpbin.org/post",
                "data": {"username": "testuser", "password": "testpass"}
            },
            {
                "url": "https://jsonplaceholder.typicode.com/posts",
                "data": {
                    "title": "Test Post",
                    "body": "This is a test post body",
                    "userId": 1
                }
            }
        ]
        
        print("Generating POST requests...")
        for item in post_data:
            try:
                response = self.session.post(
                    item["url"], 
                    json=item["data"], 
                    timeout=10
                )
                print(f"POST {item['url']} - Status: {response.status_code}")
                time.sleep(1)
            except requests.exceptions.RequestException as e:
                print(f"Error with POST {item['url']}: {e}")
    
    def generate_authenticated_requests(self):
        """Generate requests with authentication headers"""
        headers = {
            'Authorization': 'Bearer fake-jwt-token-12345',
            'X-API-Key': 'test-api-key-67890',
            'User-Agent': 'TestClient/1.0'
        }
        
        urls = [
            "https://httpbin.org/bearer",
            "https://httpbin.org/headers"
        ]
        
        print("Generating authenticated requests...")
        for url in urls:
            try:
                response = self.session.get(url, headers=headers, timeout=10)
                print(f"AUTH GET {url} - Status: {response.status_code}")
                time.sleep(1)
            except requests.exceptions.RequestException as e:
                print(f"Error with AUTH GET {url}: {e}")
    
    def generate_cookie_requests(self):
        """Generate requests with cookies"""
        # Set cookies
        self.session.cookies.set('session_id', 'abc123def456')
        self.session.cookies.set('user_pref', 'dark_mode')
        
        urls = [
            "https://httpbin.org/cookies",
            "https://httpbin.org/cookies/set/test_cookie/test_value"
        ]
        
        print("Generating cookie-based requests...")
        for url in urls:
            try:
                response = self.session.get(url, timeout=10)
                print(f"COOKIE GET {url} - Status: {response.status_code}")
                time.sleep(1)
            except requests.exceptions.RequestException as e:
                print(f"Error with COOKIE GET {url}: {e}")
    
    def run_traffic_generation(self):
        """Run complete traffic generation suite"""
        print("=== Starting Traffic Generation ===")
        print("Make sure Burp Suite is running and intercepting traffic")
        
        self.generate_get_requests()
        time.sleep(2)
        
        self.generate_post_requests()
        time.sleep(2)
        
        self.generate_authenticated_requests()
        time.sleep(2)
        
        self.generate_cookie_requests()
        
        print("\n=== Traffic Generation Complete ===")
        print("Check Burp Suite's HTTP history to analyze intercepted traffic")

def main():
    generator = TrafficGenerator()
    generator.run_traffic_generation()

if __name__ == "__main__":
    main()
