            print("[*] Phase 3: User activity simulation")
            self.simulate_user_activity()
            
            print("[+] Automated attack completed successfully")
            
        except Exception as e:
            print(f"[-] Attack failed: {e}")
        finally:
            if self.driver:
                time.sleep(5)  # Wait to see results
                self.driver.quit()

if __name__ == "__main__":
    automation = XSSAutomation()
    automation.run_automated_attack()
