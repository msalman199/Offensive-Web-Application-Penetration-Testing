        return
    
    # Generate HTML report
    html_content = generate_html_report(csv_file, domain)
    
    # Save HTML report
    html_file = f"{domain}_subdomain_report.html"
    with open(html_file, 'w') as f:
        f.write(html_content)
    
    print(f"[+] HTML report generated: {html_file}")
    
    # Generate text summary
    df = pd.read_csv(csv_file)
    summary_file = f"{domain}_summary.txt"
    
    with open(summary_file, 'w') as f:
        f.write(f"SUBDOMAIN DISCOVERY SUMMARY FOR {domain.upper()}\n")
