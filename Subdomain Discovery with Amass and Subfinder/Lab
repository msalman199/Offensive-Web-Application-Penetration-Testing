#!/usr/bin/env python3

import pandas as pd
import socket
import requests
from urllib.parse import urlparse
import sys
import warnings
warnings.filterwarnings('ignore')

class SubdomainAnalyzer:
    def __init__(self, csv_file):
        self.csv_file = csv_file
        self.df = pd.read_csv(csv_file)
        
    def check_http_status(self, subdomain):
        """Check HTTP status of subdomain"""
        for protocol in ['https', 'http']:
            try:
                url = f"{protocol}://{subdomain}"
                response = requests.get(url, timeout=10, verify=False)
                return {
                    'protocol': protocol,
                    'status_code': response.status_code,
                    'title': self.extract_title(response.text),
                    'server': response.headers.get('Server', 'Unknown')
                }
            except:
                continue
        return None
    
    def extract_title(self, html):
        """Extract title from HTML"""
        try:
            start = html.lower().find('<title>') + 7
            end = html.lower().find('</title>')
            if start > 6 and end > start:
                return html[start:end].strip()[:100]
        except:
            pass
        return "No title"
    
    def get_ip_address(self, subdomain):
        """Get IP address of subdomain"""
        try:
            return socket.gethostbyname(subdomain)
        except:
            return "N/A"
    
    def analyze_alive_subdomains(self):
        """Perform detailed analysis of alive subdomains"""
        alive_df = self.df[self.df['is_alive'] == True].copy()
        
        if len(alive_df) == 0:
            print("No alive subdomains to analyze")
            return
        
        print(f"[+] Analyzing {len(alive_df)} alive subdomains...")
        
        # Add new columns for analysis
        alive_df['ip_address'] = ''
        alive_df['http_status'] = ''
        alive_df['protocol'] = ''
        alive_df['title'] = ''
        alive_df['server'] = ''
        
        for index, row in alive_df.iterrows():
            subdomain = row['subdomain']
            print(f"[+] Analyzing {subdomain}")
            
            # Get IP address
            ip_address = self.get_ip_address(subdomain)
            alive_df.at[index, 'ip_address'] = ip_address
            
            # Check HTTP status
            http_info = self.check_http_status(subdomain)
            if http_info:
                alive_df.at[index, 'http_status'] = http_info['status_code']
                alive_df.at[index, 'protocol'] = http_info['protocol']
                alive_df.at[index, 'title'] = http_info['title']
                alive_df.at[index, 'server'] = http_info['server']
        
        # Save detailed analysis
        output_file = 'detailed_subdomain_analysis.csv'
        alive_df.to_csv(output_file, index=False)
        print(f"[+] Detailed analysis saved to: {output_file}")
        
        # Display summary
        self.display_analysis_summary(alive_df)
        
        return alive_df
    
    def display_analysis_summary(self, df):
        """Display analysis summary"""
        print("\n" + "="*60)
        print("DETAILED SUBDOMAIN ANALYSIS SUMMARY")
        print("="*60)
        
        # HTTP Status distribution
        print("\nHTTP Status Code Distribution:")
        status_counts = df['http_status'].value_counts()
        for status, count in status_counts.items():
            if status:
                print(f"  {status}: {count} subdomains")
        
        # Protocol distribution
        print("\nProtocol Distribution:")
        protocol_counts = df['protocol'].value_counts()
        for protocol, count in protocol_counts.items():
            if protocol:
                print(f"  {protocol.upper()}: {count} subdomains")
        
        # Server distribution
        print("\nServer Distribution:")
        server_counts = df['server'].value_counts().head(5)
        for server, count in server_counts.items():
            if server and server != 'Unknown':
                print(f"  {server}: {count} subdomains")
        
        # Unique IP addresses
        unique_ips = df['ip_address'].nunique()
        print(f"\nUnique IP Addresses: {unique_ips}")
        
        print("="*60)

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 advanced_analysis.py <csv_file>")
        sys.exit(1)
    
    csv_file = sys.argv[1]
    
    if not os.path.exists(csv_file):
        print(f"Error: File {csv_file} not found")
        sys.exit(1)
    
    analyzer = SubdomainAnalyzer(csv_file)
    analyzer.analyze_alive_subdomains()

if __name__ == "__main__":
    import os
    main()
EOF

