    df = pd.read_csv(csv_file)
    
    html_content = f"""
    <!DOCTYPE html>
    <html>
    <head>
        <title>Subdomain Discovery Report - {domain}</title>
        <style>
            body {{ font-family: Arial, sans-serif; margin: 40px; }}
            .header {{ background-color: #2c3e50; color: white; padding: 20px; text-align: center; }}
            .summary {{ background-color: #ecf0f1; padding: 20px; margin: 20px 0; }}
            .stats {{ display: flex; justify-content: space-around; margin: 20px 0; }}
            .stat-box {{ background-color: #3498db; color: white; padding: 15px; text-align: center; border-radius: 5px; }}
            table {{ width: 100%; border-collapse: collapse; margin: 20px 0; }}
            th, td {{ border: 1px solid #ddd; padding: 12px; text-align: left; }}
            th {{ background-color: #34495e; color: white; }}
            .alive {{ background-color: #2ecc71; color: white; }}
            .dead {{ background-color: #e74c3c; color: white; }}
        </style>
    </head>
    <body>
        <div class="header">
            <h1>Subdomain Discovery Report</h1>
            <h2>Target: {domain}</h2>
            <p>Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</p>
        </div>
        
        <div class="summary">
            <h3>Executive Summary</h3>
            <p>This report presents the results of subdomain enumeration performed on <strong>{domain}</strong> 
            using automated tools including Amass and Subfinder. The analysis identified potential attack 
            surfaces and provided insights into the target's subdomain infrastructure.</p>
        </div>
        
        <div class="stats">
            <div class="stat-box">
                <h3>{len(df)}</h3>
                <p>Total Subdomains</p>
            </div>
            <div class="stat-box">
                <h3>{len(df[df['is_alive'] == True])}</h3>
                <p>Alive Subdomains</p>
            </div>
            <div class="stat-box">
                <h3>{len(df[df['source'].str.contains('Amass')])}</h3>
                <p>Found by Amass</p>
            </div>
            <div class="stat-box">
                <h3>{len(df[df['source'].str.contains('Subfinder')])}</h3>
                <p>Found by Subfinder</p>
            </div>
        </div>
        
        <h3>Subdomain Details</h3>
        <table>
            <tr>
                <th>Subdomain</th>
                <th>Source</th>
                <th>Status</th>
                <th>Discovery Date</th>
            </tr>
    """
    
    for _, row in df.iterrows():
        status_class = "alive" if row['is_alive'] else "dead"
        status_text = "Alive" if row['is_alive'] else "Dead"
        
        html_content += f"""
            <tr>
                <td>{row['subdomain']}</td>
                <td>{row['source']}</td>
                <td class="{status_class}">{status_text}</td>
                <td>{row['discovery_date']}</td>
            </tr>
        """
    
    html_content += """
        </table>
        
        <div class="summary">
            <h3>Recommendations</h3>
            <ul>
                <li>Review all alive subdomains for potential security vulnerabilities</li>
                <li>Ensure proper access controls are in place for all discovered services</li>
                <li>Consider implementing subdomain monitoring for ongoing security</li>
