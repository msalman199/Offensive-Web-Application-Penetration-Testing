#!/usr/bin/env python3

import subprocess
import pandas as pd
import os
import sys
from datetime import datetime
import socket

class SubdomainDiscovery:
    def __init__(self, domain, output_dir):
        self.domain = domain
        self.output_dir = output_dir
        self.results = []
        
    def run_amass(self):
        """Run Amass subdomain enumeration"""
        print(f"[+] Running Amass for {self.domain}")
        try:
            cmd = f"amass enum -passive -d {self.domain}"
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=300)
            
            if result.returncode == 0:
                subdomains = result.stdout.strip().split('\n')
                subdomains = [sub.strip() for sub in subdomains if sub.strip()]
                print(f"[+] Amass found {len(subdomains)} subdomains")
                return subdomains
            else:
                print(f"[-] Amass failed: {result.stderr}")
                return []
        except subprocess.TimeoutExpired:
            print("[-] Amass timed out")
            return []
        except Exception as e:
            print(f"[-] Amass error: {str(e)}")
            return []
    
    def run_subfinder(self):
        """Run Subfinder subdomain enumeration"""
        print(f"[+] Running Subfinder for {self.domain}")
        try:
            cmd = f"subfinder -d {self.domain} -silent"
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=300)
            
            if result.returncode == 0:
                subdomains = result.stdout.strip().split('\n')
                subdomains = [sub.strip() for sub in subdomains if sub.strip()]
                print(f"[+] Subfinder found {len(subdomains)} subdomains")
                return subdomains
            else:
                print(f"[-] Subfinder failed: {result.stderr}")
                return []
        except subprocess.TimeoutExpired:
            print("[-] Subfinder timed out")
            return []
        except Exception as e:
            print(f"[-] Subfinder error: {str(e)}")
            return []
    
    def check_subdomain_alive(self, subdomain):
        """Check if subdomain resolves to an IP address"""
        try:
            socket.gethostbyname(subdomain)
            return True
        except socket.gaierror:
            return False
    
    def process_results(self, amass_results, subfinder_results):
        """Process and combine results from both tools"""
        print("[+] Processing and combining results")
        
        # Combine and deduplicate results
        all_subdomains = list(set(amass_results + subfinder_results))
        
        # Process each subdomain
        for subdomain in all_subdomains:
            if subdomain:  # Skip empty strings
                source = []
                if subdomain in amass_results:
                    source.append("Amass")
                if subdomain in subfinder_results:
                    source.append("Subfinder")
                
                # Check if subdomain is alive
                is_alive = self.check_subdomain_alive(subdomain)
                
                self.results.append({
                    'subdomain': subdomain,
                    'source': ', '.join(source),
                    'is_alive': is_alive,
                    'discovery_date': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                })
        
        print(f"[+] Processed {len(self.results)} unique subdomains")
    
    def save_to_csv(self):
        """Save results to CSV file"""
        if not self.results:
            print("[-] No results to save")
            return
        
        df = pd.DataFrame(self.results)
        csv_filename = os.path.join(self.output_dir, f"{self.domain}_subdomains.csv")
        df.to_csv(csv_filename, index=False)
        print(f"[+] Results saved to {csv_filename}")
        
        # Display summary statistics
        total_subdomains = len(df)
        alive_subdomains = len(df[df['is_alive'] == True])
        amass_only = len(df[df['source'] == 'Amass'])
        subfinder_only = len(df[df['source'] == 'Subfinder'])
        both_tools = len(df[df['source'] == 'Amass, Subfinder'])
        
        print("\n" + "="*50)
        print("SUBDOMAIN DISCOVERY SUMMARY")
        print("="*50)
        print(f"Target Domain: {self.domain}")
        print(f"Total Subdomains Found: {total_subdomains}")
        print(f"Alive Subdomains: {alive_subdomains}")
        print(f"Found by Amass Only: {amass_only}")
        print(f"Found by Subfinder Only: {subfinder_only}")
        print(f"Found by Both Tools: {both_tools}")
        print("="*50)
        
        return csv_filename
    
    def run_discovery(self):
        """Main method to run complete subdomain discovery"""
        print(f"[+] Starting subdomain discovery for {self.domain}")
        
        # Run both tools
        amass_results = self.run_amass()
        subfinder_results = self.run_subfinder()
        
        # Process results
        self.process_results(amass_results, subfinder_results)
        
        # Save to CSV
        csv_file = self.save_to_csv()
        
        return csv_file

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 subdomain_automation.py <domain>")
        sys.exit(1)
    
    domain = sys.argv[1]
    output_dir = "../results"
    
    # Create output directory if it doesn't exist
    os.makedirs(output_dir, exist_ok=True)
    
    # Run subdomain discovery
    discovery = SubdomainDiscovery(domain, output_dir)
    csv_file = discovery.run_discovery()
    
    print(f"\n[+] Subdomain discovery completed!")
    print(f"[+] Results saved to: {csv_file}")

if __name__ == "__main__":
    main()
EOF

